AC_FLAGS := \
		--target=$(OS_TRIPLET) \
		--prefix=$(ARC_BUILD_PREFIX) \
		--with-sysroot=$(ARC_SYSROOT) \
		--disable-nls \
		--disable-werror

export AC_FLAGS

# NOTE: This assumes a structure as:
#       .autogen/
#        build/
#         target-version/
#          configure
#       targets/
#        target/
#	  build
AC_CONFIG_PATH := ../$(shell realpath --relative-to=. $(ARC_SOURCE_DIR)/configure)